extends layout 

block content 
    .card 
        h1 Add New Employee

        form(action="/expenses" method="POST")

            input(type="text" name="Name" value=expenses.Name)
            input(type="text" name="Designation" value=expenses.Designation)
            input(type="text" name="EMail" value=expenses.EMail)
            input(type="number" name="Contact" value=expenses.Contact)
            input(type="text" name="Department" value=expenses.Department)
            input(type="text" name="JoiningDate" value=expenses.JoiningDate)
            input(type="text" name="Location" value=expenses.Location)
            button(type="submit") Add Employee

            a(href="/expenses") View Employee   