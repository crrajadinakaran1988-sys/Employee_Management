extends layout 

block content 
    .card 
        h1 Add New Employee

        form(action="/expenses" method="POST")

            input(type="text" name="Name" value=expense.Name)
            input(type="text" name="Designation" value=expense.Designation)
            input(type="text" name="EMail" value=expense.EMail)
            input(type="number" name="Contact" value=expense.Contact)
            input(type="text" name="Department" value=expense.Department)
            input(type="text" name="JoiningDate" value=expense.JoiningDate)
            input(type="text" name="Location" value=expense.Location)
            button(type="submit") Add Employee

            a(href="/expenses") View Employee   